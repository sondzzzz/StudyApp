<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Layout 1: Danh sách khóa học để chọn Flashcard -->
    <LinearLayout
        android:id="@+id/layout_flashcard_course_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        xmlns:tools="http://schemas.android.com/tools"
        tools:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flashcard"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2D3436"
            android:layout_marginBottom="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_flashcard_courses"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
    </LinearLayout>

    <!-- Layout 2: Màn hình học Flashcard (Đã tách ra file riêng) -->
    <include
        layout="@layout/layout_flashcard_player"
        xmlns:tools="http://schemas.android.com/tools"
        tools:visibility="gone" />

</FrameLayout>
